#!/bin/sh
# ateam — thin shim that execs the compiled Go binary.
# Resolves the workspace home so callers invoke a fixed literal path
# with no ${…} expansion in their command strings (avoids Claude Code's
# "Contains expansion" unsilenceable permission prompt).
set -eu

home="${AGENT_TEAMS_HOME:-$HOME/.agent-teams}"

if [ ! -x "$home/bin/ateam" ]; then
  echo "ateam: binary not built — run /setup-agent-teams (it runs 'go build -o \"\$home/bin/ateam\" ./cmd/ateam')" >&2
  exit 5
fi

exec "$home/bin/ateam" "$@"
