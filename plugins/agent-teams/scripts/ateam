#!/usr/bin/env bash
# ateam — agent-teams workspace-access CLI.
# Resolves the workspace path internally so callers invoke a fixed literal path
# with no ${…} expansion in their command strings (avoids Claude Code's
# "Contains expansion" unsilenceable permission prompt).
#
# Usage: ateam <verb> [args…]
# Verbs: ws | list | list-json | human-list | audit | resume-match |
#        resume-match-closed | register | note | gate | clear-gate | learn |
#        learnings | show | close | reopen | sync | new-initiative
set -euo pipefail

ATH="${AGENT_TEAMS_HOME:-$HOME/.agent-teams}"
verb="${1:-}"

# ── Guards ────────────────────────────────────────────────────────────────────
command -v bd >/dev/null 2>&1 || { echo "ateam: 'bd' not found in PATH" >&2; exit 3; }

# ws prints the path regardless of whether the workspace is initialized
if [ "$verb" = "ws" ]; then
  echo "$ATH"
  exit 0
fi

# All other verbs require an initialized workspace
if [ ! -d "$ATH/.beads" ]; then
  echo "ateam: workspace not initialized — run /setup-agent-teams (expected: $ATH/.beads)" >&2
  exit 4
fi

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "$verb" in

  list)
    bd -C "$ATH" list --status=open
    ;;

  list-json)
    bd -C "$ATH" list --status=open --json
    ;;

  human-list)
    bd -C "$ATH" human list
    ;;

  audit)
    # audit
    # Guardrail: the global workspace holds ONLY initiative-tracking beads
    # (the `register` schema, which always carries a "worktree:" line) plus role
    # memories (`bd remember`, a SEPARATE store that never appears in `bd list`).
    # Any issue here WITHOUT a "worktree:" line is a leaked feature/work/plan/
    # discovery bead — those belong in the PROJECT repo, never here.
    # Prints "clean" and exits 0 when only tracking beads exist; lists the
    # offenders and exits 1 otherwise. Covers all statuses (open and closed).
    offenders=$(bd -C "$ATH" list --all --json 2>/dev/null \
      | jq -r '[.[] | select((.description // "")
                  | split("\n")
                  | (any(startswith("worktree:")) | not))]
               | .[] | "  \(.id)\t\(.title)"' \
      2>/dev/null || true)
    if [ -z "$offenders" ]; then
      echo "audit: clean — global workspace contains only initiative-tracking beads"
      exit 0
    fi
    {
      echo "audit: LEAKED work beads in the global workspace — these belong in the PROJECT repo, NOT here:"
      printf '%s\n' "$offenders"
      echo ""
      echo "The global workspace holds ONLY initiative-tracking beads + role memories."
      echo "Move each to its project repo's .beads and delete it here (bd -C <workspace> delete <id>)."
    } >&2
    exit 1
    ;;

  resume-match)
    # resume-match <worktree-path>
    # Prints the id of the open initiative whose description contains an exact
    # line "worktree: <path>".  Prints nothing and exits 0 on no match or error.
    wt_path="${2:-}"
    if [ -z "$wt_path" ]; then
      echo "ateam resume-match: missing <worktree-path>" >&2
      exit 2
    fi
    bd -C "$ATH" list --status=open --json 2>/dev/null \
      | jq -r --arg wt "worktree: $wt_path" \
          '[.[] | select((.description // "") | split("\n") | any(. == $wt))][0].id // empty' \
      2>/dev/null || true
    ;;

  resume-match-closed)
    # resume-match-closed <worktree-path>
    # Same match as resume-match, but over CLOSED initiatives. Lets a no-param
    # /dri surface a delivered/closed initiative for the cwd instead of silently
    # ignoring it. Prints the id of the most recently created matching closed
    # initiative, or nothing on no match or error.
    wt_path="${2:-}"
    if [ -z "$wt_path" ]; then
      echo "ateam resume-match-closed: missing <worktree-path>" >&2
      exit 2
    fi
    bd -C "$ATH" list --status=closed --json 2>/dev/null \
      | jq -r --arg wt "worktree: $wt_path" \
          '[.[] | select((.description // "") | split("\n") | any(. == $wt))]
             | sort_by(.created_at) | reverse | .[0].id // empty' \
      2>/dev/null || true
    ;;

  register)
    # register --title <title> --file <bodyfile>
    # Prints ONLY the new issue id on stdout.
    reg_title=""
    reg_file=""
    shift
    while [ $# -gt 0 ]; do
      case "$1" in
        --title) reg_title="$2"; shift 2 ;;
        --title=*) reg_title="${1#--title=}"; shift ;;
        --file) reg_file="$2"; shift 2 ;;
        --file=*) reg_file="${1#--file=}"; shift ;;
        *) echo "ateam register: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    [ -n "$reg_title" ] || { echo "ateam register: --title required" >&2; exit 2; }
    [ -n "$reg_file" ]  || { echo "ateam register: --file required" >&2; exit 2; }
    [ -f "$reg_file" ]  || { echo "ateam register: file not found: $reg_file" >&2; exit 2; }

    # bd create outputs a line like:
    #   ✓ Created at-abc123 — <title>
    # Parse the id from that output (most direct and reliable).
    create_out=$(bd -C "$ATH" create --title="$reg_title" --type=task --priority=2 \
      --body-file="$reg_file" 2>&1)
    new_id=$(printf '%s\n' "$create_out" \
      | grep -oE 'at-[a-z0-9]+' \
      | head -1) || true
    if [ -z "$new_id" ]; then
      # Fallback: find newest open issue matching the title via list-json
      new_id=$(bd -C "$ATH" list --status=open --json 2>/dev/null \
        | jq -r --arg t "$reg_title" \
            '[.[] | select(.title == $t)] | sort_by(.created_at) | reverse | .[0].id // empty' \
        2>/dev/null || true)
    fi
    echo "$new_id"
    ;;

  note)
    # note <id> --file <file>
    note_id="${2:-}"
    [ -n "$note_id" ] || { echo "ateam note: missing <id>" >&2; exit 2; }
    note_file=""
    shift 2
    while [ $# -gt 0 ]; do
      case "$1" in
        --file) note_file="$2"; shift 2 ;;
        --file=*) note_file="${1#--file=}"; shift ;;
        *) echo "ateam note: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    [ -n "$note_file" ] || { echo "ateam note: --file required" >&2; exit 2; }
    [ -f "$note_file" ] || { echo "ateam note: file not found: $note_file" >&2; exit 2; }
    bd -C "$ATH" note "$note_id" --file="$note_file"
    ;;

  gate)
    # gate <id> --file <file>
    # Combined: note the question + add human label.
    gate_id="${2:-}"
    [ -n "$gate_id" ] || { echo "ateam gate: missing <id>" >&2; exit 2; }
    gate_file=""
    shift 2
    while [ $# -gt 0 ]; do
      case "$1" in
        --file) gate_file="$2"; shift 2 ;;
        --file=*) gate_file="${1#--file=}"; shift ;;
        *) echo "ateam gate: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    [ -n "$gate_file" ] || { echo "ateam gate: --file required" >&2; exit 2; }
    [ -f "$gate_file" ] || { echo "ateam gate: file not found: $gate_file" >&2; exit 2; }
    bd -C "$ATH" note "$gate_id" --file="$gate_file"
    bd -C "$ATH" label add "$gate_id" human
    ;;

  clear-gate)
    # clear-gate <id> [--file <responsefile>]
    # If --file given: comment the response. Always removes human label.
    cg_id="${2:-}"
    [ -n "$cg_id" ] || { echo "ateam clear-gate: missing <id>" >&2; exit 2; }
    cg_file=""
    shift 2
    while [ $# -gt 0 ]; do
      case "$1" in
        --file) cg_file="$2"; shift 2 ;;
        --file=*) cg_file="${1#--file=}"; shift ;;
        *) echo "ateam clear-gate: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    if [ -n "$cg_file" ]; then
      [ -f "$cg_file" ] || { echo "ateam clear-gate: file not found: $cg_file" >&2; exit 2; }
      bd -C "$ATH" comment "$cg_id" --file="$cg_file"
    fi
    bd -C "$ATH" label remove "$cg_id" human
    ;;

  learn)
    # learn <role> <slug> --file <file>
    learn_role="${2:-}"
    learn_slug="${3:-}"
    [ -n "$learn_role" ] || { echo "ateam learn: missing <role>" >&2; exit 2; }
    [ -n "$learn_slug" ] || { echo "ateam learn: missing <slug>" >&2; exit 2; }
    learn_file=""
    shift 3
    while [ $# -gt 0 ]; do
      case "$1" in
        --file) learn_file="$2"; shift 2 ;;
        --file=*) learn_file="${1#--file=}"; shift ;;
        *) echo "ateam learn: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    [ -n "$learn_file" ] || { echo "ateam learn: --file required" >&2; exit 2; }
    [ -f "$learn_file" ] || { echo "ateam learn: file not found: $learn_file" >&2; exit 2; }
    # Command substitution inside this script is invisible to the safety matcher.
    bd -C "$ATH" remember --key "${learn_role}:${learn_slug}" "$(cat "$learn_file")"
    ;;

  learnings)
    # learnings <role>
    lr_role="${2:-}"
    [ -n "$lr_role" ] || { echo "ateam learnings: missing <role>" >&2; exit 2; }
    bd -C "$ATH" memories "$lr_role"
    ;;

  show)
    # show <id>
    show_id="${2:-}"
    [ -n "$show_id" ] || { echo "ateam show: missing <id>" >&2; exit 2; }
    bd -C "$ATH" show "$show_id"
    ;;

  close)
    # close <id> [--reason <text>] [--file <reasonfile>]
    cl_id="${2:-}"
    [ -n "$cl_id" ] || { echo "ateam close: missing <id>" >&2; exit 2; }
    cl_reason=""
    cl_file=""
    shift 2
    while [ $# -gt 0 ]; do
      case "$1" in
        --reason) cl_reason="$2"; shift 2 ;;
        --reason=*) cl_reason="${1#--reason=}"; shift ;;
        --file) cl_file="$2"; shift 2 ;;
        --file=*) cl_file="${1#--file=}"; shift ;;
        *) echo "ateam close: unknown flag '$1'" >&2; exit 2 ;;
      esac
    done
    if [ -n "$cl_file" ]; then
      [ -f "$cl_file" ] || { echo "ateam close: file not found: $cl_file" >&2; exit 2; }
      cl_reason="$(cat "$cl_file")"
    fi
    if [ -n "$cl_reason" ]; then
      bd -C "$ATH" close "$cl_id" --reason="$cl_reason"
    else
      bd -C "$ATH" close "$cl_id"
    fi
    ;;

  reopen)
    # reopen <id>
    # Reopen a closed initiative (e.g. a no-param /dri resuming a delivered
    # initiative the human chose to continue). Targets the global workspace, so
    # the skill never needs a raw bd call with an ${AGENT_TEAMS_HOME} expansion.
    ro_id="${2:-}"
    [ -n "$ro_id" ] || { echo "ateam reopen: missing <id>" >&2; exit 2; }
    bd -C "$ATH" reopen "$ro_id"
    ;;

  sync)
    bd -C "$ATH" dolt push
    ;;

  new-initiative)
    # new-initiative <directory> <dri-arg…>
    # Spawn a background DRI whose cwd is <directory>, forwarding <dri-arg> to
    # the /dri command. claude has no working-directory flag, so cwd is set by
    # launching from inside <directory> — doing it here keeps the caller's
    # command fixed-form (no --cwd, no cd in the caller string).
    #   The dri-dispatch skill passes the INITIATIVE ID it just registered, so
    #   the bg DRI resumes that exact initiative (/dri <id>) — robust, with no
    #   dependence on $PWD matching the registered worktree path. An ad-hoc
    #   caller may instead pass a problem statement, in which case the bg DRI
    #   self-registers on first boot. Either way the arg is just forwarded.
    ni_dir="${2:-}"
    [ -n "$ni_dir" ] || { echo "ateam new-initiative: missing <directory>" >&2; exit 2; }
    [ -d "$ni_dir" ] || { echo "ateam new-initiative: not a directory: $ni_dir" >&2; exit 2; }
    shift 2
    ni_arg="$*"
    [ -n "$ni_arg" ] || { echo "ateam new-initiative: missing <dri-arg> (initiative id or problem statement)" >&2; exit 2; }
    command -v claude >/dev/null 2>&1 || { echo "ateam new-initiative: 'claude' not found in PATH" >&2; exit 3; }
    ni_name=$(basename "$ni_dir")
    cd "$ni_dir" && claude --bg -n "$ni_name" --permission-mode bypassPermissions "/dri $ni_arg"
    ;;

  "")
    echo "ateam: verb required" >&2
    printf 'Usage: ateam <verb> [args]\nVerbs: ws | list | list-json | human-list | audit | resume-match | resume-match-closed\n       register | note | gate | clear-gate | learn | learnings\n       show | close | reopen | sync | new-initiative\n' >&2
    exit 2
    ;;

  *)
    echo "ateam: unknown verb '$verb'" >&2
    printf 'Usage: ateam <verb> [args]\nVerbs: ws | list | list-json | human-list | audit | resume-match | resume-match-closed\n       register | note | gate | clear-gate | learn | learnings\n       show | close | reopen | sync | new-initiative\n' >&2
    exit 2
    ;;

esac
