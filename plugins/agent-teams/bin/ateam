#!/bin/sh
# POSIX dispatch wrapper — selects the prebuilt ateam binary for the current
# platform and exec's it.  Reachable via Claude Code's plugin bin/ PATH
# auto-add or via a symlink in ~/.local/bin; the resolution loop below
# handles both.
set -eu

# Resolve $0 through chained symlinks (POSIX; handles absolute and relative
# link targets) so dir points at the real bin/ containing platform binaries,
# not the symlink's directory.
src="$0"
while [ -h "$src" ]; do
    target="$(readlink "$src")"
    case "$target" in
        /*) src="$target" ;;
        *)  src="$(dirname "$src")/$target" ;;
    esac
done
dir="$(cd "$(dirname "$src")" && pwd)"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

raw_arch="$(uname -m)"
case "$raw_arch" in
    x86_64)  ARCH=amd64 ;;
    aarch64) ARCH=arm64 ;;
    arm64)   ARCH=arm64 ;;
    *)       ARCH="$raw_arch" ;;
esac

target="$dir/ateam-${OS}-${ARCH}"

if [ -x "$target" ]; then
    exec "$target" "$@"
fi

printf 'ateam: unsupported platform %s-%s\n' "$OS" "$ARCH" >&2
printf 'available binaries:\n' >&2
for b in "$dir"/ateam-*; do
    case "$b" in
        *ateam-*-*) printf '  %s\n' "$(basename "$b")" >&2 ;;
    esac
done
exit 1
